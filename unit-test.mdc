# Java 单元测试规则

## 测试框架

### 核心依赖
```xml
<!-- JUnit 5 -->
<dependency>
    <groupId>org.junit.jupiter</groupId>
    <artifactId>junit-jupiter</artifactId>
    <scope>test</scope>
</dependency>

<!-- Mockito -->
<dependency>
    <groupId>org.mockito</groupId>
    <artifactId>mockito-core</artifactId>
    <scope>test</scope>
</dependency>

<!-- Spring Boot Test -->
<dependency>
    <groupId>org.springframework.boot</groupId>
    <artifactId>spring-boot-starter-test</artifactId>
    <scope>test</scope>
</dependency>

<!-- AssertJ (可选，更好的断言) -->
<dependency>
    <groupId>org.assertj</groupId>
    <artifactId>assertj-core</artifactId>
    <scope>test</scope>
</dependency>
```

## 测试类命名规范

### 命名规则
- 测试类名 = 被测试类名 + Test
- 测试方法名：`test方法名_场景描述_预期结果`
- 使用 `@DisplayName` 添加中文描述

```java
// 被测试类
public class UserService {
    public User getUserById(Long id) { }
}

// 测试类
@DisplayName("用户服务测试")
class UserServiceTest {
    
    @Test
    @DisplayName("根据ID查询用户 - 用户存在 - 返回用户信息")
    void testGetUserById_userExists_returnUser() {
        // 测试代码
    }
    
    @Test
    @DisplayName("根据ID查询用户 - 用户不存在 - 抛出异常")
    void testGetUserById_userNotExists_throwException() {
        // 测试代码
    }
}
```

## 测试类基本结构

### Controller 测试模板
```java
@WebMvcTest(UserController.class)
@DisplayName("用户控制器测试")
class UserControllerTest {
    
    @Autowired
    private MockMvc mockMvc;
    
    @MockBean
    private UserService userService;
    
    @Autowired
    private ObjectMapper objectMapper;
    
    @Test
    @DisplayName("创建用户 - 参数正确 - 返回成功")
    void testCreateUser_validParams_returnSuccess() throws Exception {
        // Given: 准备测试数据
        UserCreateDTO dto = new UserCreateDTO();
        dto.setUsername("test");
        dto.setPassword("123456");
        
        UserVO expectedUser = new UserVO();
        expectedUser.setId(1L);
        expectedUser.setUsername("test");
        
        when(userService.createUser(any(UserCreateDTO.class)))
            .thenReturn(expectedUser);
        
        // When: 执行测试
        mockMvc.perform(post("/api/v1/users")
                .contentType(MediaType.APPLICATION_JSON)
                .content(objectMapper.writeValueAsString(dto)))
                // Then: 验证结果
                .andExpect(status().isOk())
                .andExpect(jsonPath("$.code").value(200))
                .andExpect(jsonPath("$.data.id").value(1))
                .andExpect(jsonPath("$.data.username").value("test"));
        
        // 验证 Service 调用
        verify(userService, times(1)).createUser(any(UserCreateDTO.class));
    }
    
    @Test
    @DisplayName("创建用户 - 用户名为空 - 返回400错误")
    void testCreateUser_emptyUsername_return400() throws Exception {
        // Given
        UserCreateDTO dto = new UserCreateDTO();
        dto.setUsername("");
        dto.setPassword("123456");
        
        // When & Then
        mockMvc.perform(post("/api/v1/users")
                .contentType(MediaType.APPLICATION_JSON)
                .content(objectMapper.writeValueAsString(dto)))
                .andExpect(status().isBadRequest());
    }
}
```

### Service 测试模板
```java
@ExtendWith(MockitoExtension.class)
@DisplayName("用户服务测试")
class UserServiceTest {
    
    @Mock
    private UserMapper userMapper;
    
    @Mock
    private RedisTemplate<String, Object> redisTemplate;
    
    @InjectMocks
    private UserServiceImpl userService;
    
    @Test
    @DisplayName("创建用户 - 用户名不存在 - 创建成功")
    void testCreateUser_usernameNotExists_createSuccess() {
        // Given: 准备测试数据
        UserCreateDTO dto = new UserCreateDTO();
        dto.setUsername("test");
        dto.setPassword("123456");
        
        User savedUser = new User();
        savedUser.setId(1L);
        savedUser.setUsername("test");
        
        when(userMapper.existsByUsername("test")).thenReturn(false);
        when(userMapper.insert(any(User.class))).thenReturn(1);
        
        // When: 执行测试方法
        UserVO result = userService.createUser(dto);
        
        // Then: 验证结果
        assertThat(result).isNotNull();
        assertThat(result.getUsername()).isEqualTo("test");
        
        // 验证方法调用
        verify(userMapper, times(1)).existsByUsername("test");
        verify(userMapper, times(1)).insert(any(User.class));
    }
    
    @Test
    @DisplayName("创建用户 - 用户名已存在 - 抛出异常")
    void testCreateUser_usernameExists_throwException() {
        // Given
        UserCreateDTO dto = new UserCreateDTO();
        dto.setUsername("test");
        
        when(userMapper.existsByUsername("test")).thenReturn(true);
        
        // When & Then
        assertThatThrownBy(() -> userService.createUser(dto))
            .isInstanceOf(BusinessException.class)
            .hasMessageContaining("用户名已存在");
        
        // 验证没有调用 insert
        verify(userMapper, never()).insert(any(User.class));
    }
    
    @Test
    @DisplayName("根据ID查询用户 - 缓存命中 - 返回缓存数据")
    void testGetUserById_cacheHit_returnCachedData() {
        // Given
        Long userId = 1L;
        UserVO cachedUser = new UserVO();
        cachedUser.setId(userId);
        cachedUser.setUsername("test");
        
        ValueOperations<String, Object> valueOps = mock(ValueOperations.class);
        when(redisTemplate.opsForValue()).thenReturn(valueOps);
        when(valueOps.get("user:1")).thenReturn(cachedUser);
        
        // When
        UserVO result = userService.getUserById(userId);
        
        // Then
        assertThat(result).isNotNull();
        assertThat(result.getId()).isEqualTo(userId);
        
        // 验证没有查询数据库
        verify(userMapper, never()).selectById(anyLong());
    }
}
```

### Mapper 测试模板
```java
@SpringBootTest
@Transactional
@DisplayName("用户Mapper测试")
class UserMapperTest {
    
    @Autowired
    private UserMapper userMapper;
    
    @Test
    @DisplayName("插入用户 - 成功")
    void testInsert_success() {
        // Given
        User user = new User();
        user.setUsername("test");
        user.setPassword("123456");
        user.setEmail("test@example.com");
        
        // When
        int result = userMapper.insert(user);
        
        // Then
        assertThat(result).isEqualTo(1);
        assertThat(user.getId()).isNotNull();
    }
    
    @Test
    @DisplayName("根据用户名查询 - 用户存在 - 返回用户")
    void testSelectByUsername_userExists_returnUser() {
        // Given: 先插入数据
        User user = new User();
        user.setUsername("test");
        user.setPassword("123456");
        userMapper.insert(user);
        
        // When
        User result = userMapper.selectByUsername("test");
        
        // Then
        assertThat(result).isNotNull();
        assertThat(result.getUsername()).isEqualTo("test");
    }
    
    @Test
    @DisplayName("分页查询用户 - 返回分页结果")
    void testSelectUserPage_returnPageResult() {
        // Given: 插入测试数据
        for (int i = 1; i <= 15; i++) {
            User user = new User();
            user.setUsername("user" + i);
            user.setPassword("123456");
            userMapper.insert(user);
        }
        
        Page<User> page = new Page<>(1, 10);
        
        // When
        IPage<User> result = userMapper.selectUserPage(page, "user");
        
        // Then
        assertThat(result.getRecords()).hasSize(10);
        assertThat(result.getTotal()).isEqualTo(15);
        assertThat(result.getPages()).isEqualTo(2);
    }
}
```

## 测试用例编写原则

### AAA 模式（推荐）

```java
@Test
void testMethodName() {
    // Arrange (Given): 准备测试数据和环境
    UserCreateDTO dto = new UserCreateDTO();
    dto.setUsername("test");
    
    when(userMapper.existsByUsername("test")).thenReturn(false);
    
    // Act (When): 执行被测试的方法
    UserVO result = userService.createUser(dto);
    
    // Assert (Then): 验证结果
    assertThat(result).isNotNull();
    assertThat(result.getUsername()).isEqualTo("test");
}
```

### Given-When-Then 模式

```java
@Test
@DisplayName("创建用户 - 完整流程")
void testCreateUser_completeFlow() {
    // Given: 准备条件
    UserCreateDTO dto = UserCreateDTO.builder()
        .username("test")
        .password("123456")
        .email("test@example.com")
        .build();
    
    when(userMapper.existsByUsername("test")).thenReturn(false);
    when(userMapper.insert(any(User.class))).thenReturn(1);
    
    // When: 执行操作
    UserVO result = userService.createUser(dto);
    
    // Then: 验证结果
    assertThat(result)
        .isNotNull()
        .extracting("username", "email")
        .containsExactly("test", "test@example.com");
    
    verify(userMapper).existsByUsername("test");
    verify(userMapper).insert(any(User.class));
}
```

## 断言（Assertions）

### JUnit 5 断言
```java
// 基本断言
assertEquals(expected, actual);
assertNotEquals(expected, actual);
assertTrue(condition);
assertFalse(condition);
assertNull(object);
assertNotNull(object);

// 异常断言
assertThrows(BusinessException.class, () -> {
    userService.createUser(null);
});

// 超时断言
assertTimeout(Duration.ofSeconds(1), () -> {
    userService.complexOperation();
});

// 组合断言
assertAll("user",
    () -> assertEquals("test", user.getUsername()),
    () -> assertNotNull(user.getEmail()),
    () -> assertTrue(user.getAge() > 0)
);
```

### AssertJ 断言（推荐）
```java
// 对象断言
assertThat(user)
    .isNotNull()
    .extracting("username", "email")
    .containsExactly("test", "test@example.com");

// 集合断言
assertThat(users)
    .isNotEmpty()
    .hasSize(10)
    .extracting(User::getUsername)
    .contains("test1", "test2");

// 异常断言
assertThatThrownBy(() -> userService.createUser(null))
    .isInstanceOf(BusinessException.class)
    .hasMessage("参数不能为空");

// 条件断言
assertThat(user.getAge())
    .isGreaterThan(0)
    .isLessThan(150);

// 字符串断言
assertThat(user.getUsername())
    .isNotBlank()
    .startsWith("test")
    .hasSize(10);
```

## Mock 使用规范

### Mockito 基本用法

```java
// 1. 创建 Mock 对象
@Mock
private UserMapper userMapper;

// 2. 注入 Mock 对象
@InjectMocks
private UserServiceImpl userService;

// 3. 定义 Mock 行为
when(userMapper.selectById(1L)).thenReturn(user);
when(userMapper.insert(any(User.class))).thenReturn(1);

// 4. 抛出异常
when(userMapper.selectById(999L))
    .thenThrow(new BusinessException("用户不存在"));

// 5. 验证方法调用
verify(userMapper).selectById(1L);
verify(userMapper, times(1)).insert(any(User.class));
verify(userMapper, never()).deleteById(anyLong());

// 6. 参数捕获
ArgumentCaptor<User> captor = ArgumentCaptor.forClass(User.class);
verify(userMapper).insert(captor.capture());
User capturedUser = captor.getValue();
assertThat(capturedUser.getUsername()).isEqualTo("test");
```

### MockMvc 使用

```java
// GET 请求
mockMvc.perform(get("/api/v1/users/1"))
    .andExpect(status().isOk())
    .andExpect(jsonPath("$.data.id").value(1));

// POST 请求
mockMvc.perform(post("/api/v1/users")
        .contentType(MediaType.APPLICATION_JSON)
        .content(objectMapper.writeValueAsString(dto)))
    .andExpect(status().isOk())
    .andExpect(jsonPath("$.code").value(200));

// PUT 请求
mockMvc.perform(put("/api/v1/users/1")
        .contentType(MediaType.APPLICATION_JSON)
        .content(objectMapper.writeValueAsString(dto)))
    .andExpect(status().isOk());

// DELETE 请求
mockMvc.perform(delete("/api/v1/users/1"))
    .andExpect(status().isOk());

// 带请求头
mockMvc.perform(get("/api/v1/users")
        .header("Authorization", "Bearer token"))
    .andExpect(status().isOk());

// 带查询参数
mockMvc.perform(get("/api/v1/users")
        .param("pageNum", "1")
        .param("pageSize", "10")
        .param("keyword", "test"))
    .andExpect(status().isOk());
```

